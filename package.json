{
  "name": "sunny-acres",
  "version": "0.1.0",
  "private": true,
  "description": "Competitive multiplayer farming-and-trading game.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/client",
    "build": "npm run build -w packages/shared && npm run build -w apps/client",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  }
}
